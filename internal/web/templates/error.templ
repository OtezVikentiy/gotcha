package templates

import "strconv"

// ErrorPage — стилизованная страница ошибки (404, 500 и т.д.) поверх общего
// layout: status/msg приходят от web.Handler.renderError, чтобы не голым
// http.Error ронять вид сайта на ошибках.
templ ErrorPage(status int, msg string, userEmail string) {
	@layout(strconv.Itoa(status), userEmail) {
		<div class="error-page">
			<p class="error-code">{ strconv.Itoa(status) }</p>
			<p class="error">{ msg }</p>
			<p><a href="/">На главную</a></p>
		</div>
	}
}
