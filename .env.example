# Gotcha configuration — all variables are read with prefix GOTCHA_.
# Copy this file to .env and adjust. See cmd/gotcha/config.go for the
# authoritative source of truth (defaults/validation) and README.md for
# a narrative walkthrough of the most important settings.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# HTTP listen address.
GOTCHA_ADDR=:8080

# Public URL of this instance. Used to build project DSNs, alert/incident
# links, and invite links — must match how users actually reach the
# instance (scheme+host+port). Non-local (non-localhost) values force
# GOTCHA_SECRET_KEY to be a real secret (see Security below) and log a
# warning if not https://.
GOTCHA_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string (relational state: orgs, projects, users,
# issues, alert rules, incidents).
GOTCHA_PG_DSN=postgres://gotcha:gotcha@localhost:5432/gotcha?sslmode=disable

# ClickHouse connection string (high-volume data: events, spans, metrics,
# profiles, uptime results).
GOTCHA_CH_DSN=clickhouse://localhost:9000/gotcha

# ---------------------------------------------------------------------------
# Email (SMTP) — used for invite emails and the email alert channel.
# Email delivery is disabled until GOTCHA_SMTP_HOST is set.
# ---------------------------------------------------------------------------

GOTCHA_SMTP_HOST=
GOTCHA_SMTP_PORT=587
GOTCHA_SMTP_USER=
GOTCHA_SMTP_PASSWORD=
GOTCHA_SMTP_FROM=

# ---------------------------------------------------------------------------
# Retention (ClickHouse data, in days)
# ---------------------------------------------------------------------------

# Events / transactions / Web Vitals retention.
GOTCHA_RETENTION_DAYS=90

# Trace spans retention.
GOTCHA_SPAN_RETENTION_DAYS=30

# Metric points retention.
GOTCHA_METRIC_RETENTION_DAYS=30

# Profile samples retention.
GOTCHA_PROFILE_RETENTION_DAYS=7

# Notification outbox retention (delivered/failed alert deliveries carry
# channel secrets in their payload — kept short by default).
GOTCHA_OUTBOX_RETENTION_DAYS=7

# ---------------------------------------------------------------------------
# Quotas & edition
# ---------------------------------------------------------------------------

# Build edition: oss | saas. Controls the *default* for the quota
# variables below (oss -> 0/unlimited, saas -> 1000000/month). An explicit
# GOTCHA_DEFAULT_*_QUOTA below always overrides this default.
GOTCHA_EDITION=oss

# Default monthly ingest quotas assigned to new organizations.
# 0 = unlimited. oss default is 0 (unlimited) for all four.
# If you expose a project DSN publicly, set these to a real cap — the oss
# default of "unlimited" means a leaked/public DSN can ingest without bound.
GOTCHA_DEFAULT_EVENT_QUOTA=0
GOTCHA_DEFAULT_TRANSACTION_QUOTA=0
GOTCHA_DEFAULT_METRIC_QUOTA=0
GOTCHA_DEFAULT_PROFILE_QUOTA=0

# Maximum accepted size (bytes) of a single ingested event payload.
GOTCHA_MAX_EVENT_BYTES=1048576

# How often (seconds) the metric threshold-alert evaluator runs.
GOTCHA_METRIC_EVAL_INTERVAL=60

# How often (seconds) the profile regression evaluator runs.
GOTCHA_PROFILE_EVAL_INTERVAL=300

# ---------------------------------------------------------------------------
# Privacy
# ---------------------------------------------------------------------------

# Zero out the reporting user's IP / email server-side before storage.
# On by default (PII scrubbing).
GOTCHA_SCRUB_IP=true
GOTCHA_SCRUB_EMAIL=true

# Comma-separated key names (case-insensitive) redacted from
# tags/contexts/stack traces/span data. Setting this overrides the
# built-in denylist entirely. Built-in default denylist:
#   password,passwd,token,secret,authorization,auth,cookie,api_key,apikey,
#   access_token,refresh_token,session,credit_card,card_number,cvv
#GOTCHA_SCRUB_KEYS=password,passwd,token,secret,authorization,auth,cookie,api_key,apikey,access_token,refresh_token,session,credit_card,card_number,cvv

# Optionally mask email addresses found in free text (message / exception
# value / span description). Off by default — conservative, since naive
# masking can corrupt SQL/URLs in free text. Only emails are masked, not
# phone numbers or other PII.
GOTCHA_SCRUB_FREETEXT=false

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Signs OAuth state/session cookies.
# !!! The default value below is PUBLIC (it ships in source) and allows
# OAuth-based account takeover. Generate a strong random value for any
# non-localhost deployment, e.g.: openssl rand -base64 32
# The app refuses to start in web/all mode against a non-local
# GOTCHA_BASE_URL while this is left at the default (escape hatch for
# unusual dev setups: GOTCHA_ALLOW_INSECURE_SECRET=1).
GOTCHA_SECRET_KEY=insecure-dev-secret

# Self-registration mode: open | invite | closed. The very first user on a
# fresh instance always succeeds regardless of this setting and becomes
# instance-admin (bootstrap).
GOTCHA_REGISTRATION=invite

# Allow uptime checks and outbound webhook alert deliveries to target
# private/loopback/link-local addresses. Keep false on any multi-tenant or
# internet-facing instance (SSRF protection).
GOTCHA_SSRF_ALLOW_PRIVATE=false

# Apply database schema migrations automatically on startup. Set to false
# to run migrations as a separate init job (e.g. so multiple app replicas
# don't all race to migrate at once) — the app then refuses to start
# against a schema that isn't current.
GOTCHA_AUTO_MIGRATE=true

# Include error text (title/culprit/body) in outbound alert channels
# (Telegram/webhook). If false, only an anonymized link back to the
# instance is sent (error text may carry personal data you don't want
# leaving the instance).
GOTCHA_EXTERNAL_CHANNEL_DETAILS=true

# Escape hatch: allow starting in web/all mode with the default
# GOTCHA_SECRET_KEY on a non-local GOTCHA_BASE_URL. Development only —
# never set this in a real deployment. Unset/false by default.
#GOTCHA_ALLOW_INSECURE_SECRET=false

# ---------------------------------------------------------------------------
# Uptime & probe
# ---------------------------------------------------------------------------

# How many uptime checks run concurrently (uptime|all modes), and how many
# concurrent checks a remote probe (--mode=probe) runs.
GOTCHA_UPTIME_CONCURRENCY=50

# Name of the built-in local uptime-check region.
GOTCHA_LOCAL_REGION=local

# --mode=probe only: bearer token this probe authenticates to the central
# instance with. Required when GOTCHA_SERVER_URL is set / --mode=probe.
GOTCHA_PROBE_TOKEN=

# --mode=probe only: base URL of the central Gotcha instance this probe
# reports to. Must be an absolute http(s) URL. Required for --mode=probe.
GOTCHA_SERVER_URL=

# ---------------------------------------------------------------------------
# OAuth / SSO
# Each provider is enabled independently; enabling one without its
# required secrets refuses to start.
# ---------------------------------------------------------------------------

# Generic OIDC provider.
GOTCHA_OIDC_ENABLED=false
GOTCHA_OIDC_ISSUER=
GOTCHA_OIDC_CLIENT_ID=
GOTCHA_OIDC_CLIENT_SECRET=
GOTCHA_OIDC_SCOPES=
GOTCHA_OIDC_NAME=

# Yandex ID.
GOTCHA_YANDEX_ENABLED=false
GOTCHA_YANDEX_CLIENT_ID=
GOTCHA_YANDEX_CLIENT_SECRET=

# VK ID.
GOTCHA_VK_ENABLED=false
GOTCHA_VK_CLIENT_ID=
GOTCHA_VK_CLIENT_SECRET=
